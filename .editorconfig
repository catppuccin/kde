root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# inkscape exports carry trailing whitespace; not ours to reflow
[*.svg]
trim_trailing_whitespace = false

# markdown uses two trailing spaces for hard line breaks
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# json across the repo is space-indented; shell is left to shfmt
[*.json]
indent_style = space
